# ============================================================
# CDS — City Operating System — Environment Configuration
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# Generate JWT_SECRET_KEY: openssl rand -hex 32
# ============================================================

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=cds
POSTGRES_PASSWORD=change_me_in_production

# Identity service DB (used by identity-service)
IDENTITY_DATABASE_URL=postgresql://cds:change_me_in_production@postgres-identity:5432/cds_identity

# Application services DB (used by all other services)
DATABASE_URL=postgresql://cds:change_me_in_production@postgres-app:5432/cds_app

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://:redis_secret@redis:6379/0
REDIS_PASSWORD=redis_secret

# ── Kafka ────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka1:9092,kafka2:9092,kafka3:9092
KAFKA_SCHEMA_REGISTRY_URL=http://schema-registry:8081

# ── JWT Authentication ───────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=replace_with_64_char_hex_secret_never_commit_this
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_HOURS=8

# ── Service Configuration ────────────────────────────────────
# SERVICE_NAME is injected per-service via docker-compose
LOG_LEVEL=INFO

# ── Observability ────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317

# ── Email (SMTP) ─────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@municipality.gov
SMTP_PASSWORD=change_me
SMTP_TLS=true

# ── MinIO (Object Storage) ───────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin_secret
MINIO_SECURE=false

# ── Internal Service URLs ────────────────────────────────────
IDENTITY_SERVICE_URL=http://identity-service:8000

# ── Grafana ──────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin_secret
